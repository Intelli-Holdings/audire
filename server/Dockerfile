# syntax=docker/dockerfile:1.7

# ---- Build stage ---------------------------------------------------------
# Pinned to a specific Rust release so reproducible builds don't drift.
FROM rust:1.83-slim-bookworm AS builder

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        pkg-config \
        libssl-dev \
        ca-certificates \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy the workspace manifests first so dependency compilation can be
# cached across source-only changes.
COPY Cargo.toml Cargo.lock ./
COPY shared/Cargo.toml shared/Cargo.toml
COPY server/Cargo.toml server/Cargo.toml

# Stub crates so `cargo fetch` succeeds with the manifest layout above.
RUN mkdir -p shared/src server/src \
 && echo "fn main() {}" > server/src/main.rs \
 && echo "" > shared/src/lib.rs \
 && cargo fetch --locked

# Bring in the real sources.
COPY shared shared
COPY server server
COPY migrations migrations

# sqlx offline metadata — generated by `cargo sqlx prepare` and committed
# to git so the build doesn't need a live database.
COPY .sqlx .sqlx
ENV SQLX_OFFLINE=true

RUN cargo build --release --locked --bin audire-server \
 && strip target/release/audire-server

# ---- Runtime stage -------------------------------------------------------
FROM debian:bookworm-slim AS runtime

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        ca-certificates \
        libssl3 \
        tini \
 && rm -rf /var/lib/apt/lists/* \
 && groupadd --system --gid 10001 audire \
 && useradd  --system --uid 10001 --gid audire --home /app audire

WORKDIR /app
COPY --from=builder /build/target/release/audire-server /usr/local/bin/audire-server
COPY --from=builder /build/migrations /app/migrations

USER audire
ENV BIND_ADDR=0.0.0.0:8080
EXPOSE 8080

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/audire-server"]
