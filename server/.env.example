# Audire Sync server — local development configuration.
# Copy to `.env` and fill in real values. Never commit a populated `.env`.

# Postgres connection string. For local dev point this at a local
# Postgres or a Neon branch. The DB user must own the `audire` schema
# (the migration creates it).
DATABASE_URL=postgres://audire:audire@localhost:5432/audire

# Bind address for the HTTP server.
BIND_ADDR=0.0.0.0:8080

# Stack Auth (running in your Neon project as the OSS auth backend).
# All three are required.
#
#   STACK_AUTH_PROJECT_ID  — the project UUID shown in the Stack dashboard
#   STACK_AUTH_JWKS_URL    — the JWKS endpoint, e.g.
#                            https://api.stack-auth.com/api/v1/projects/<id>/.well-known/jwks.json
#   STACK_AUTH_AUDIENCE    — the audience claim we expect on access tokens
STACK_AUTH_PROJECT_ID=
STACK_AUTH_JWKS_URL=
STACK_AUTH_AUDIENCE=audire-sync

# Tracing filter. `audire_server=info` is a good default; bump to debug
# while developing.
RUST_LOG=audire_server=info,tower_http=info,sqlx=warn
