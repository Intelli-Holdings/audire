<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Microphone access for voice input on the chat page (Web Speech API)
         and for any future native mic capture path. Without this entitlement
         WebKit will silently reject getUserMedia / SpeechRecognition with
         a NotAllowedError. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Network access for ASR providers (Deepgram / AssemblyAI websockets)
         and LLM gateways. The hardened runtime blocks outbound traffic
         without this entitlement. -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Allow the app to read its own bundled helper binaries (audire_sck_helper). -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required when the app spawns the SCK helper subprocess. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
